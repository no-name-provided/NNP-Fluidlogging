{
  "required": true,
  "minVersion": "0.8",
  "package": "com.github.no_name_provided.nnp_fluidlogging.mixins",
  "compatibilityLevel": "JAVA_21",
  "mixins": [
    "FFluidlogging_BlockBehavior",
    "FFluidlogging_FlowingFluid",
    "FFluidlogging_LeavesBlock",
    "FFluidlogging_LevelChunk",
    "FFluidlogging_LevelChunkSection",
    "FFluidlogging_LiquidBlock",
    "FFluidlogging_ServerLevel",
    "FFluidlogging_SimpleWaterloggedBlock",
    "FFluidlogging_SlabBlock",
    "FFluidlogging_StairBlock"
  ],
  "client": [
    "FFluidlogging_LiquidBlockRenderer",
    "FFluidlogging_RenderChunkRegion",
    "FFluidlogging_SectionCompiler"
  ],
  "injectors": {
    "defaultRequire": 1
  },
  "overwrites": {
    "requireAnnotations": true
  }
}
